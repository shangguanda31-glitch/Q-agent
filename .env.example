# NapCatQQ 配置
NAPCAT_WS_URL=ws://127.0.0.1:4447
NAPCAT_HTTP_URL=http://127.0.0.1:4444
NAPCAT_TOKEN=your_token_here

# Web 面板
WEB_PORT=5050

# LLM — 两种后端选择
# OpenVINO (Intel GPU): http://127.0.0.1:8000
# llama.cpp (NVIDIA GPU): http://127.0.0.1:8081
LLM_URL=http://127.0.0.1:8000
LLM_MODEL=qwen3.5-9b-openvino
EMBED_URL=http://127.0.0.1:8082

# Claude Code
CLAUDE_CODE_TIMEOUT=120
CLAUDE_CODE_ENABLED=true
CLAUDE_WORKING_DIR=./claude_workspace
